    <exercise label="L3-3-3_Calculate_Output">
      <title>
        Practice calculating the output
      </title>
      <idx>Calculate output 1</idx>
      <statement>
        <p>Calculate the output of this circuit.</p>
        <image source="L3_3_3_Calculate.png" width="75%" />
      </statement>
      <choices randomize="yes">
        <choice correct="no">
          <statement>
            <p>
              <m>\ket{00}</m>
            </p>
          </statement>
          <feedback>
            <p> </p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>
              <m>\ket{01}</m>
            </p>
          </statement>
          <feedback>
            <p> </p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>
              <m>\ket{10}</m>
            </p>
          </statement>
          <feedback>
            <p>Correct!</p>
          </feedback>
        </choice>
        <choice correct="no">
          <statement>
            <p>
              <m>\ket{11}</m>
            </p>
          </statement>
          <feedback>
            <p> </p>
          </feedback>
        </choice>
      </choices>
      <hint>
        <p>Think about what the output would be after each gate.
          Remember the compressed notation for more than one qubit lists qubit states from top to
          bottom.</p>
      </hint>
    </exercise>

    <exercise label="L3-3-4_Calculate_Output">
      <title>
        Practice calculating the output
      </title>
      <idx>Calculate output 2</idx>
      <statement>
        <p>Calculate the output of this circuit.</p>
        <image source="L3_3_4_Calculate.png" width="75%" />
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>
              <m>\ket{00}</m>
            </p>
          </statement>
          <feedback>
            <p>Correct!</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>
              <m>\ket{01}</m>
            </p>
          </statement>
          <feedback>
            <p> </p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>
              <m>\ket{10}</m>
            </p>
          </statement>
          <feedback>
            <p> </p>
          </feedback>
        </choice>
        <choice correct="no">
          <statement>
            <p>
              <m>\ket{11}</m>
            </p>
          </statement>
          <feedback>
            <p> </p>
          </feedback>
        </choice>
      </choices>
      <hint>
        <p>Think about what the output would be after each gate.
          Remember the compressed notation for more than one qubit lists qubit states from top to
          bottom.</p>
      </hint>
    </exercise>
  </section>
</section>
