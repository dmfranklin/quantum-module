<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="lesson3_5" xmlns:xi="http://www.w3.org/2001/XInclude">

  <title>Problem Set</title>

  <exercise label="HW3_Q1">
    <title>Question #1</title>
    <idx>HW3 Q1</idx>
    <statement>
      <p>Select the statement that states the probability of measuring 1 or ⚫ in the following visual representation.</p>
      <image source="L3_5_visualState1.png" width="10%" />
    </statement>
    <choices randomize="yes">
      <choice>
        <statement>
          <p>Outcome will definitely be <m>\ket{0}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
          <p>Outcome will definitely be <m>\ket{1}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
          <p>Equal probabilities of measuring <m>\ket{0}</m> or <m>\ket{1}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
          <p>Greater probability of measuring <m>\ket{0}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
          <p>Greater probability of measuring <m>\ket{1}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>

  <exercise label="HW3_Q2">
    <title>Question #2</title>
    <idx>HW3 Q2</idx>
    <statement>
      <p>Calculate the state at A.</p>
      <image source="L3_5_CalculateStateABC.png" width="90%" />
    </statement>
    <choices randomize="yes">
      <choice correct="yes">
        <statement>
            <p>Black</p>
            <image source="L4_3_2_A.png" width="25%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p>White</p>
            <image source="L4_3_2_B.png" width="25%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p>50/50 superposition of white and black, positive phase</p>
            <image source="L4_3_2_D.png" width="25%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p>50/50 superposition of white and black balls, negative phase</p>
            <image source="L4_3_2_E.png" width="25%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p>50/50 superposition of white and black balls, unknown phase</p>
            <image source="L4_3_2_F.png" width="35%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>

