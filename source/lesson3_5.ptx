  <exercise label="HW3_Q5">
    <title>Question #5</title>
    <idx>HW3 Q5</idx>
    <statement>
      <p>What gate should be added to the end of the cicuit to produce an output that is the same as the input?</p>
      <image source="L3_5_CalculateStateABC.png" width="90%" />
    </statement>
    <choices randomize="yes">
      <choice>
        <statement>
            <p><c>Z</c> gate</p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
            <p><c>NOT</c> gate</p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p><c>H</c> gate</p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p>No gate is needed.</p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>

