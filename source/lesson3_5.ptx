  <!-- Is it possible to suppress this statement from the widget? 
  "Given the input state |0⟩, create a circuit that produces the output state 0.707|0⟩ - 0.707|1⟩."
   -->
  <exercise label="HW3-Q10">
    <title>Question #10</title>
    <idx>HW3 Q10</idx>
    <statement>
      <p>Given an input state of <m>\ket{1}</m>, create a circuit with an output that matches the visual representation shown below.</p>
      <image source="Visual_Onebit_50_positive.png" width="10%" />
    <interactive aspect="9:9" platform="javascript" source="https://cdn.jsdelivr.net/gh/dmfranklin/quantum-module/source/loader.js">
      <script>
        specificOutputWidget({
          circuit: "L3_5_SpecificOutput",
          instantFeedback: false,
          allowedGates: "ZHX",
          inputs: "1"
        });
      </script>
    </interactive>
    </statement>
  </exercise>


