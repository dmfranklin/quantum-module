<exercise label="HW3_Q7">
    <title>Question #7</title>
    <idx>HW3 Q7</idx>
    <statement>
      <p>Select the statement(s) that describe two qubits.</p>
    </statement>
    <choices randomize="no">
      <choice>
        <statement>
            <p> </p>
            <image source="L4_3_2_A.png" width="20%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p> </p>
            <image source="L4_3_2_D.png" width="25%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
            <p> </p>
            <image source="L4_3_2_G.png" width="25%" />
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
            <p><m>\ket{10}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
            <p><m>\ket{1}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>      
      <choice>
        <statement>
            <p><m>\ket{0}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
            <p><m>\ket{11}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
            <p><m>\ket{0}</m> and <m>\ket{0}</m></p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>




  <exercise label="HW3-Q8">
