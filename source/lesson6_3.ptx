<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="lesson6_3" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Problem Set</title>

  <exercises>
    <exercise label="HW6_Q1">
      <title>Question #1</title>
      <idx>HW6 Q1</idx>
      <statement>
        <p>Which property distinguishes a change in global phase of a quantum state?</p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> All amplitudes are multiplied by the same factor </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Only one basis amplitude is changed </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> The state's probabilities change </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> The measurement outcomes change </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q2">
      <title>Question #2</title>
      <idx>HW6 Q2</idx>
      <statement>
        <p>True or False: Two quantum states that differ only by a global phase have identical
          physical meaning and measurement outcomes.</p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>True</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>False</p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q3">
      <title>Question #3</title>
      <idx>HW6 Q3</idx>
      <statement>
        <p>Which pair of states differ by a relative phase?</p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>
              <m>\frac{1}{\sqrt{2}}(|0\rangle + |1\rangle)</m> and <m>\frac{1}{\sqrt{2}}(|0\rangle - |1\rangle)</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>|0\rangle</m> and <m>-|0\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>|1\rangle</m> and <m>|0\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>\frac{1}{\sqrt{2}}(|0\rangle + |1\rangle)</m> and <m>|1\rangle</m>
            </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q4">
      <title>Question #4</title>
      <idx>HW6 Q4</idx>
      <statement>
        <p> What happens when the Z gate acts on <m>|1\rangle</m>? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> Multiplies <m>|1\rangle</m> and <m>-1</m> (global phase) </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Produces <m>|0\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Multiplies <m>|1\rangle</m> by <m>i</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Leaves <m>|1\rangle</m> unchanged</p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q5">
      <title>Question #5</title>
      <idx>HW6 Q5</idx>
      <statement>
        <p>What is the output when the Z gate acts on <m>\frac{1}{\sqrt{2}}(|0\rangle + |1\rangle)</m> ?</p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>
              <m> \frac{1}{\sqrt{2}}(|0\rangle - |1\rangle) </m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m> \frac{1}{\sqrt{2}}(|0\rangle + |1\rangle) </m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>|1\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>|0\rangle</m>
            </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q6">
      <title>Question #6</title>
      <idx>HW6 Q6</idx>
      <statement>
        <p>When does the <c>CZ</c> gate introduce a phase change? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> Only when both qubits are <m>|1\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Only when both qubits are <m>|0\rangle</m></p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>For any superposition input</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>For all basis states</p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q7">
      <title>Question #7</title>
      <idx>HW6 Q7</idx>
      <statement>
        <p> What is phase kickback in quantum computing? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> The target qubit's phase is transferred to the control </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> The control qubit's state is unchanged by controlled gates </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>A qubit's amplitude becomes zero </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> The NOT gate changes both qubits </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q8">
      <title>Question #8</title>
      <idx>HW6 Q8</idx>
      <statement>
        <p> Which sequence produces phase kickback in a two-qubit system with initial state <m>|01\rangle</m>
          ? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> Apply H gates to both qubits, then CNOT </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Apply X gates to both qubits </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Apply CNOT only </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Apply Z gate to first qubit </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q9">
      <title>Question #9</title>
      <idx>HW6 Q9</idx>
      <statement>
        <p> After applying Hadamard gates to <m>|0\rangle\otimes|1\rangle</m>, which bra-ket state results? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>
              <m>\frac{1}{2}|00\rangle - \frac{1}{2}|01\rangle + \frac{1}{2}|10\rangle - \frac{1}{2}|11\rangle </m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>\frac{1}{2}|00\rangle + \frac{1}{2}|01\rangle + \frac{1}{2}|10\rangle + \frac{1}{2}|11\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>|01\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>|00\rangle</m>
            </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q10">
      <title>Question #10</title>
      <idx>HW6 Q10</idx>
      <statement>
        <p> What does the CNOT gate (with the first qubit as the control and the second qubit as the
          target) do to the state <m> \frac{1}{2}|00\rangle - \frac{1}{2}|01\rangle + \frac{1}{2}|10\rangle - \frac{1}{2}|11\rangle </m>? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> It flips the second qubit only when the first is <m>|1\rangle</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> It swaps the qubits </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> It flips the phase on the second qubit </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> It removes all negative signs </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q11">
      <title>Question #11</title>
      <idx>HW6 Q11</idx>
      <statement>
        <p> After applying Hadamard and CNOT gates to a two-qubit system. What do you observe when
          factoring the resulting state? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> Both qubits are in equal superposition with negative phase </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> The second qubit is always zero </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Both amplitudes become negative </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> States revert to original </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q12">
      <title>Question #12</title>
      <idx>HW6 Q12</idx>
      <statement>
        <p> Do the following states differ by global phase or relative phase? <md>
            <mrow>|\psi_1\rangle = |0\rangle</mrow>
            <mrow>|\psi_2\rangle = -|0\rangle</mrow>
          </md>
        </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> Global phase </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Relative phase </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW6_Q13">
      <title>Question #13</title>
      <idx>HW6 Q13</idx>
      <statement>
        <p> Do the following states differ by global phase or relative phase? <md>
            <mrow>|\phi_1\rangle = \frac{1}{\sqrt{2}}(|0\rangle + |1\rangle)</mrow>
            <mrow>|\phi_2\rangle = \frac{1}{\sqrt{2}}(-|0\rangle + |1\rangle)</mrow>
          </md>
        </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> Relative phase </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Global phase </p>
          </statement>
        </choice>
      </choices>
    </exercise>

  </exercises>
</section>
