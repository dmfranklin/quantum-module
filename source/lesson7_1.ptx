  <exercises>
    <exercisegroup>
      <title>How Qiskit Represents Quantum States</title>
      <exercise label="HW7-1_Q1">
        <title>Question #1</title>
        <idx>HW7.1 Q1</idx>
        <statement>
          <p>Identify the line of code that displays the state in <em>vector notation</em>.</p>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <c>array_to_latex(state0, prefix="\\text{state0} = ")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state0 = Statevector.from_label("0")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state0.draw("latex")</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-1_Q2">
        <title>Question #2</title>
        <idx>HW7.1 Q2</idx>
        <statement>
          <p>Identify the line of code that displays the state in <em>bra-ket notation</em>.</p>
        </statement>
        <choices randomize="yes">
          <choice>
            <statement>
              <p>
                <c>array_to_latex(state0, prefix="\\text{state0} = ")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state0 = Statevector.from_label("0")</c>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <c>state0.draw("latex")</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-1_Q3">
        <title>Question #3</title>
        <idx>HW7.1 Q3</idx>
        <statement>
          <p>Select all that will set the state to <m>\ket{1}</m>:</p>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <c>state0 = Statevector.from_label("1")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state0 = Statevector.from_label("0")</c>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <c>state0 = Statevector([0, 1])</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state0 = Statevector([1, 0])</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>
    </exercisegroup>
