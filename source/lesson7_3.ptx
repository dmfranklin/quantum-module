  <exercises>
    <exercisegroup>
      <title>Notation for 2-Qubit States</title>
      <exercise label="HW7-3_Q1">
        <title>Question #1</title>
        <idx>HW7.3 Q1</idx>
        <statement>
          <p>Convert the two independent qubits shown below into 2-qubit bra-ket notation.</p>
          <md>0\ket{0} + 1\ket{1}, 0.6\ket{0} + 0.8\ket{1}</md>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <m>0.6\ket{10} + 0.8\ket{11}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>0.8\ket{10} + 0.6\ket{11}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>0.6\ket{00} + 0.8\ket{01} + 0.6\ket{10} + 0.8\ket{11}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>0.8\ket{00} + 0.6\ket{01} + 0.8\ket{10} + 0.6\ket{11}</m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-3_Q2">
        <title>Question #2</title>
        <idx>HW7.3 Q2</idx>
        <statement>
          <p>Convert the state <m>0.6\ket{00} + 0.8\ket{11}</m> to vector notation.</p>
        </statement>
        <choices randomize="yes">
          <choice>
            <statement>
              <p>
                <m>\begin{bmatrix}0.6\\0.8\\0\\0\end{bmatrix}</m>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <m>\begin{bmatrix}0.6\\0\\0\\0.8\end{bmatrix}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>\begin{bmatrix}0.8\\0\\0\\0.6\end{bmatrix}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>\begin{bmatrix}0\\0.6\\0.8\\0\end{bmatrix}</m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>
    </exercisegroup>

    <exercisegroup>
      <title>Two-Qubit States in Qiskit</title>

      <exercise label="HW7-3_Q3">
        <title>Question #3</title>
        <idx>HW7.3 Q3</idx>
        <statement>
          <p>Select all that will set the state to <m>\ket{00}</m>:</p>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <c>state00 = Statevector.from_label("00")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state00 = Statevector.from_label("11")</c>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <c>state00 = Statevector([1, 0, 0, 0])</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state00 = Statevector([0, 0, 0, 1])</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-3_Q4">
        <title>Question #4</title>
        <idx>HW7.3 Q4</idx>
        <statement>
          <p>Two qubit states are defined in the Qiskit code shown below.</p>
          <program language="python3">
            from qiskit.quantum_info import Statevector
            from math import sqrt

            stateA = Statevector([1/2, -sqrt(3)/2])
            stateB = Statevector.from_label("0")
          </program>
          <p>Write a line of Qiskit code that combines these independent qubit states into a 2-qubit
            state.</p>
        </statement>
        <response />
        <hint>
          <p> Your line of code will begin: <c>stateAB = </c>
          </p>
        </hint>
      </exercise>

      <exercise label="HW7-3_Q5">
        <title>Question #5</title>
        <idx>HW7.3 Q5</idx>
        <statement>
          <p>A state of two qubits is created by the Qiskit code shown below. Identify the line of
            code that returns the <em>probabilities of the measurement outcomes</em> of this state.</p>
          <program language="python3">
            state12 = Statevector([1/sqrt(6), 1/sqrt(2), 1/sqrt(3), 0])
          </program>
        </statement>
        <choices randomize="yes">
          <choice>
            <statement>
              <p>
                <c>probabilities(state12)</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>meas_probabilities(state12)</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>state12.meas_probabilities()</c>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <c>state12.probabilities_dict()</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>
    </exercisegroup>

    <exercisegroup>
      <title>Matrix Multiplication with <m>4x4</m> Matrices</title>

      <exercise label="HW7-3_Q6">
        <title>Question #6</title>
        <idx>HW7.3 Q6</idx>
        <statement>
          <p> We want to multiply the matrix and vector. Which of the following computes the <em>
            second</em> element of the <em>result vector</em>? </p>
          <md>
            \begin{bmatrix}2\amp 0\amp 0\amp 1\\0\amp 0\amp 5\amp 1\amp \\3\amp -2\amp 0\amp 0\\4\amp
            4\amp 0\amp 6\end{bmatrix}
            \begin{bmatrix}1\\2\\2\\-2\end{bmatrix}
          </md>
        </statement>
        <choices randomize="yes">
          <choice>
            <statement>
              <p>
                <m>2 \cdot 1 + 0 \cdot 2 + 0 \cdot 2 + 6 \cdot (-2)</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>0 \cdot 2</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>0 \cdot 0 + 5 \cdot 1 + 3 \cdot (-2) + 0 \cdot 0</m>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <m>0 \cdot 1 + 0 \cdot 2 + 5 \cdot 2 + 1 \cdot (-2)</m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-3_Q7">
        <title>Question #7</title>
        <idx>HW7.3 Q7</idx>
        <statement>
          <p>Write a line of Qiskit code that creates the following <em>4x4 matrix</em>, as an
            Operator object.</p>
          <md>Av = \begin{bmatrix}
            1 \amp 1 \amp 0 \amp 0\\
            1 \amp 0 \amp 0 \amp 3\\
            0 \amp 0 \amp -2 \amp 0\\
            0 \amp 0 \amp 1 \amp 0
          \end{bmatrix} \begin{bmatrix}
            4 \\ 1 \\ -3 \\ 2
          \end{bmatrix}
          </md>
        </statement>
        <response />
        <hint>
          <p>Your line of code will begin: <c>A = </c></p>
        </hint>
      </exercise>

      <exercise label="HW7-3_Q8">
        <title>Question #8</title>
        <idx>HW7.3 Q8</idx>
        <statement>
          <p>Write a line of Qiskit code that creates the <em>initial vector</em>, as an Operator
            object.</p>
          <md>Av = \begin{bmatrix}
            1 \amp 1 \amp 0 \amp 0\\
            1 \amp 0 \amp 0 \amp 3\\
            0 \amp 0 \amp -2 \amp 0\\
            0 \amp 0 \amp 1 \amp 0
          \end{bmatrix} \begin{bmatrix}
            4 \\ 1 \\ -3 \\ 2
          \end{bmatrix}
          </md>
        </statement>
        <response />
        <hint>
          <p>Your line of code will begin: <c>v = </c></p>
        </hint>
      </exercise>

      <exercise label="HW7-3_Q9">
        <title>Question #9</title>
        <idx>HW7.3 Q9</idx>
        <statement>
          <p>Write a line of Qiskit code that <em>multiplies the matrix and the vector</em>.</p>
          <md>Av = \begin{bmatrix}
            1 \amp 1 \amp 0 \amp 0\\
            1 \amp 0 \amp 0 \amp 3\\
            0 \amp 0 \amp -2 \amp 0\\
            0 \amp 0 \amp 1 \amp 0
          \end{bmatrix} \begin{bmatrix}
            4 \\ 1 \\ -3 \\ 2
          \end{bmatrix}
          </md>
        </statement>
        <response />
        <hint>
          <p>Your line of code will begin: <c>result_vector = </c></p>
        </hint>
      </exercise>
    </exercisegroup>

    <exercisegroup>
      <title>Matrix Multiplication with Quantum Gates</title>

      <exercise label="HW7-3_Q10">
        <title>Question 10</title>
        <idx>HW7.3 Q10</idx>
        <statement>
          <p> What is the matrix for the <em>CNOT gate (CX gate)</em>, where the first qubit is the
            control and the second qubit is the target? </p>
        </statement>
        <choices randomize="yes">
          <choice>
            <statement>
              <p>
                <m>
            \begin{bmatrix}
              1 \amp 0 \amp 0 \amp 0 \\
              0 \amp 1 \amp 0 \amp 0 \\
              0 \amp 0 \amp 1 \amp 0 \\
              0 \amp 0 \amp 0 \amp 1 \\
            \end{bmatrix}
                </m>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <m>
            \begin{bmatrix}
              1 \amp 0 \amp 0 \amp 0 \\
              0 \amp 1 \amp 0 \amp 0 \\
              0 \amp 0 \amp 0 \amp 1 \\
              0 \amp 0 \amp 1 \amp 0 \\
            \end{bmatrix}
                </m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>
            \begin{bmatrix}
              \frac{1}{\sqrt{2}} \amp \frac{1}{\sqrt{2}} \\
              \frac{1}{\sqrt{2}} \amp -\frac{1}{\sqrt{2}} \\
            \end{bmatrix}
                </m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>
            \begin{bmatrix}
              0 \amp 1 \\
              1 \amp 0
            \end{bmatrix}
                </m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-3_Q11">
        <title>Question 11</title>
        <idx>HW7.3 Q11</idx>
        <statement>
          <p>What is the <c>result_state</c> from the <c>CNOT</c> (<c>CX</c>) circuit shown below?</p>
          <image source="HW7-3_Q11.png" width="35%" />
        </statement>
        <choices randomize="yes">
          <choice>
            <statement>
              <p>
                <m>\begin{bmatrix}\frac{1}{\sqrt{2}} \amp \frac{1}{\sqrt{2}} \amp 0 \amp 0 \end{bmatrix}</m>
              </p>
            </statement>
          </choice>
          <choice correct="yes">
            <statement>
              <p>
                <m>\begin{bmatrix}0 \amp \frac{1}{\sqrt{2}} \amp \frac{1}{\sqrt{2}} \amp 0 \end{bmatrix}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>\begin{bmatrix}0 \amp 0 \amp \frac{1}{\sqrt{2}} \amp \frac{1}{\sqrt{2}} \end{bmatrix}</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>\begin{bmatrix}\frac{1}{\sqrt{2}} \amp 0 \amp 0 \amp \frac{1}{\sqrt{2}} \end{bmatrix}</m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>
    </exercisegroup>
  </exercises>
