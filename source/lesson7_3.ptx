  <exercises>
    <exercisegroup>
      <title>How to do Matrix Multiplication</title>
      <exercise label="HW7-2_Q1">
        <title>Question #1</title>
        <idx>HW7.2 Q1</idx>
        <statement>
          <p>From the example: What is the <em>first</em> element of the result vector?</p>
          <md>2 \cdot 3 + (-5) \cdot (-2) =</md>
        </statement>
        <response />
      </exercise>

      <exercise label="HW7-2_Q2">
        <title>Question #2</title>
        <idx>HW7.2 Q2</idx>
        <statement>
          <p>From the example: What is the <em>second</em> element of the result vector?</p>
          <md>(-1) \cdot 3 + 4 \cdot (-2) =</md>
        </statement>
        <response />
      </exercise>

      <exercise label="HW7-2_Q3">
        <title>Question #3</title>
        <idx>HW7.2 Q3</idx>
        <statement>
          <p>We want to multiply the following matrix and vector. Which of the following computes
            the <em>first</em> element of the <em>result vector</em>?</p>
          <md>
              \begin{bmatrix}2\amp 0 \\ 5 \amp 3\end{bmatrix}
              \begin{bmatrix}-1 \\ 7 \end{bmatrix}
            </md>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <m>2 \cdot (-1) + 0 \cdot 7</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>5 \cdot (-1) + 3 \cdot 7</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>2 \cdot 0 + (-1) \cdot 7</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>2 \cdot (-1) + 5 \cdot (-1)</m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-2_Q4">
        <title>Question #4</title>
        <idx>HW7.2 Q4</idx>
        <statement>
          <p>We want to multiply the following matrix and vector. Which of the following computes
            the <em>second</em> element of the <em>result vector</em>?</p>
          <md>
              \begin{bmatrix}2\amp 0 \\ 5 \amp 3\end{bmatrix}
              \begin{bmatrix}-1 \\ 7 \end{bmatrix}
            </md>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <m>5 \cdot (-1) + 3 \cdot 7</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>2 \cdot 0 + (-1) \cdot 7</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>5 \cdot 3 + (-1) \cdot 7</m>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <m>3 \cdot 7</m>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>
    </exercisegroup>

    <exercisegroup>
      <title>How to do Matrix Multiplication in Qiskit</title>

      <exercise label="HW7-2_Q5">
        <title>Question #5</title>
        <idx>HW7.2 Q5</idx>
        <statement>
          <p>
            What class represents matrices in Qiskit?
          </p>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <c>Operator</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>Grid</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>Matrix</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>Matrices</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-2_Q6">
        <title>Question #6</title>
        <idx>HW7.2 Q6</idx>
        <statement>
          <p>Identify the line of code that displays matrix <m>A</m> created in Qiskit by <c>Operator()</c>.</p>
        </statement>
        <choices randomize="yes">
          <choice correct="yes">
            <statement>
              <p>
                <c>array_to_latex(A, prefix="\\text{A} = ")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>A.draw("latex")</c>
              </p>
            </statement>
          </choice>
          <choice>
            <statement>
              <p>
                <c>A.from_label("draw")</c>
              </p>
            </statement>
          </choice>
        </choices>
      </exercise>

      <exercise label="HW7-2_Q7">
        <title>Question #7</title>
        <idx>HW7.2 Q7</idx>
        <statement>
          <p>Write a line of Qiskit code that multiplies the matrix <m>A</m> and the vector <m>x</m>
            and assigns the result to <m>y</m>.</p>
        </statement>
        <response />
        <hint>
          <statement>
            <p> Your line of code will begin: <c>y = </c>
            </p>
          </statement>
        </hint>
      </exercise>
    </exercisegroup>

