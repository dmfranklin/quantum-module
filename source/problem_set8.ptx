<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="problemset8" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Problem Set</title>

  <exercises>
    <exercise label="HW8_Q1">
      <title>Question #1</title>
      <idx>HW8 Q1</idx>
      <statement>
        <p>Entanglement defines the following relationship between qubits:</p>
      </statement>
      <choices randomize="yes">
        <choice>
          <statement>
            <p> If you measure one qubit, then you know what the other
              qubit's value is </p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p> If you measure one qubit, then the probability of measurement outcomes
              of the other qubit changes. </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> If you measure one qubit, then it does not affect the state of the other
              qubit. </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW8_Q2">
      <title>Question #2</title>
      <idx>HW8 Q2</idx>
      <statement>
        <p>Which of the following statements is most accurate?</p>
      </statement>
      <choices randomize="yes">
        <choice>
          <statement>
            <p>We both understand how entanglement works and can predict its effects</p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p>We do not understand how entanglement works, but we can predict its
              effects</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>We neither understand how entanglement works nor how it affects the
              outcomes of involved qubits</p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW8_Q3">
      <title>Question #3</title>
      <idx>HW8 Q3</idx>
      <statement correct="yes">
        <p>When qubits are entangled, the outcomes of measurements is no longer independent.</p>
      </statement>
    </exercise>

    <exercise label="HW8_Q4">
      <title>Question #4</title>
      <idx>HW8 Q4</idx>
      <statement>
        <p> The definitive way to identify if a quantum state is entangled is: </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p> The state cannot be split into individual qubits. </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> The state has an overall negative phase. </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Such a state cannot be mathematically represented. </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>All outcomes are identical.</p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW8_Q5">
      <title>Question #5</title>
      <idx>HW8 Q5</idx>
      <statement correct="no">
        <p>The only way to entangle two qubits is with a <c>CNOT</c> and an <c>H</c> gate.</p>
      </statement>
    </exercise>

    <exercise label="HW8_Q6">
      <title>Question #6</title>
      <idx>HW8 Q6</idx>
      <statement>
        <p>Determine the quantum state that results from the following circuit:</p>
        <image source="HW8_6.png" width="50%" />
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>
              <m> \ket{\Phi}^+ = \frac{1}{\sqrt{2}} (\ket{00} + \ket{11}) = \frac{1}{\sqrt{2}} \begin{bmatrix}1\\0\\0\\1\end{bmatrix} </m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m> \ket{\Phi}^- = \frac{1}{\sqrt{2}} (\ket{00} - \ket{11}) = \frac{1}{\sqrt{2}} \begin{bmatrix}1\\0\\0\\-1\end{bmatrix} </m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m> \ket{\Psi}^+ = \frac{1}{\sqrt{2}} (\ket{01} + \ket{10}) = \frac{1}{\sqrt{2}} \begin{bmatrix}0\\1\\1\\0\end{bmatrix} </m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m> \ket{\Psi}^- = \frac{1}{\sqrt{2}} (\ket{01} - \ket{10}) = \frac{1}{\sqrt{2}} \begin{bmatrix}0\\1\\-1\\0\end{bmatrix} </m>
            </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW8_Q7">
      <title>Question #7</title>
      <idx>HW8 Q7</idx>
      <statement>
        <p> Mark all tasks that do not require copying classical information. </p>
      </statement>
      <choices randomize="yes" multiple-correct="yes">
        <choice>
          <statement>
            <p> Loading information from a flash drive onto your MacBook </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Saving a snapshot from your phone to the cloud </p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p>Clearing browser cache</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Adding redundant (copied) bits for error correction on a transmitted message </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW8_Q8">
      <title>Question #8</title>
      <idx>HW8 Q8</idx>
      <statement correct="no">
        <p>The no-cloning theorem refers to the fact that if you measure a bit to place into
          classical storage, you lose the quantum properties of it. </p>
      </statement>
    </exercise>

    <exercise label="HW8_Q9">
      <title>Question #9</title>
      <idx>HW8 Q9</idx>
      <statement correct="no">
        <p> The no-cloning theorem refers to the fact that in order to copy a qubit, it must be
          stored in a quantum storage device. </p>
      </statement>
    </exercise>

    <exercise label="HW8_Q10">
      <title>Question #10</title>
      <idx>HW8 Q10</idx>
      <statement correct="yes">
        <p> The no-cloning theorem refers to the fact that if you make a copy of a qubit, the
          original qubit must have been changed in the process (e.g. you can move, but not copy,
          qubits). </p>
      </statement>
    </exercise>

    <exercise label="HW8_Q11">
      <title>Question #11</title>
      <idx>HW8 Q11</idx>
      <statement>
        <p> Quantum teleportation is used for: </p>
      </statement>
      <choices randomize="yes">
        <choice>
          <statement>
            <p> Transporting information faster than the speed of light </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Transporting information back in time </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Transporting NON LIVING physical objects from one point to another (i.e. across a
              lab space)</p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p>Transporting qubit state faster than physically moving that qubit from point a to
              point b </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW8_Q12">
      <title>Question #12</title>
      <idx>HW8 Q12</idx>
      <statement>
        <p> Which of these statements is true vs. false? </p>
        <p> (a) You need 1 classical bit for every qubit transported by quantum teleportation. </p>
        <p> (b) The classical transfer of information prohibits communications from being faster
          than the speed of light. </p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p> Both true </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Both false </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Only (a) true </p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p> Only (b) true </p>
          </statement>
        </choice>
      </choices>
    </exercise>

  </exercises>
</section>
