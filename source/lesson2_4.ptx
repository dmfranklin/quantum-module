<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="lesson2_4" xmlns:xi="http://www.w3.org/2001/XInclude">

  <title>Problem Set</title>

  <exercise label="HW2_Q1">
    <title>Question #1</title>
    <idx>HW2 Q1</idx>
    <statement>
      <p>What is the state of the two qubits after the NOT gate?</p>
      <image source="HW2_2qubitsNOT.png" width="40%" />
    </statement>
    <choices randomize="no">
      <choice>
        <statement>
          <p>
            <m>\ket{00}</m> or <m>\ket{⚪⚪}</m>
          </p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
          <p>
            <m>\ket{01}</m> or <m>\ket{⚪⚫}</m>
          </p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement>
          <p>
            <m>\ket{10}</m> or <m>\ket{⚫⚪}</m>
          </p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement>
          <p>
            <m>\ket{11}</m> or <m>\ket{⚫⚫}</m>
          </p>
        </statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>


  <exercise label="HW2_Q2">
    <title>Question #2</title>
    <idx>HW2 Q2</idx>
    <statement>
      <p>In the circuit below, which qubit is the control of the CNOT gate?</p>
      <image source="HW2_4qubitsCNOT.png" width="40%" />
    </statement>
    <choices randomize="no">
      <choice>
        <statement><p>Qubit 0 (top qubit)</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p>Qubit 1</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Qubit 2</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Qubit 3 (bottom qubit)</p></statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>


  <exercise label="HW2_Q3">
    <title>Question #3</title>
    <idx>HW2 Q3</idx>
    <statement>
      <p>In the circuit below, which qubit is the target of the CNOT gate?</p>
      <image source="HW2_4qubitsCNOT.png" width="40%" />
