  <exercise label="HW2_Q4">
    <title>Question #4</title>
    <idx>HW2 Q4</idx>
    <statement>
      <p>How do you modify the circuit so the qubits are in the state <m>\ket{10}</m> at the input of the SWAP gate?</p>
      <image source="HW2_2qubitsSWAP.png" width="40%" />
    </statement>
    <choices randomize="no">
      <choice>
        <statement><p>Don't need to do anything.</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p>Add a NOT gate to qubit 0</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Add a NOT gate to qubit 1</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Add a NOT gate to qubit 0 and qubit 1</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Need to do something else</p></statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>


  <exercise label="HW2_Q5">
    <title>Question #5</title>
    <idx>HW2 Q5</idx>
    <statement>
      <p>What is the output state when the input state is <m>\ket{10}</m>?</p>
      <image source="HW2_2qubitsSWAP.png" width="40%" />
    </statement>
    <choices randomize="no">
      <choice>
        <statement><p><m>\ket{00}</m> or <m>\ket{⚪⚪}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p><m>\ket{01}</m> or <m>\ket{⚪⚫}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p><m>\ket{10}</m> or <m>\ket{⚫⚪}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p><m>\ket{11}</m> or <m>\ket{⚫⚫}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>            
    </choices>
    <hint><p> </p></hint>
  </exercise>


  <exercise label="HW2_Q6">
    <title>Question #6</title>
    <idx>HW2 Q6</idx>
    <statement>
      <p>How do you modify the circuit so the qubits are in the state <m>\ket{11}</m> at the output of the SWAP gate?</p>
      <image source="HW2_2qubitsSWAP.png" width="40%" />
    </statement>
    <choices randomize="no">
      <choice>
        <statement><p>Don't need to do anything.</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Add a NOT gate to qubit 0</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Add a NOT gate to qubit 1</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p>Add a NOT gate to qubit 0 and qubit 1</p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p>Need to do something else</p></statement>
        <feedback><p> </p></feedback>
      </choice>
    </choices>
    <hint>
      <p> </p>
    </hint>
  </exercise>


