  <exercise label="HW2_Q8">
    <title>Question #8</title>
    <idx>HW2 Q8</idx>
    <statement>
      <p>Which input state(s) would result in an output that differs from the original input? Select all that apply.</p>
      <image source="HW2_2qubitsCNOT.png" width="40%" />
    </statement>
    <choices randomize="no">
      <choice>
        <statement><p><m>\ket{00}</m> or <m>\ket{⚪⚪}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice>
        <statement><p><m>\ket{01}</m> or <m>\ket{⚪⚫}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p><m>\ket{10}</m> or <m>\ket{⚫⚪}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p><m>\ket{11}</m> or <m>\ket{⚫⚫}</m></p></statement>
        <feedback><p> </p></feedback>
      </choice>            
    </choices>
    <hint><p> </p></hint>
  </exercise>


  <exercise label="HW2-Q9">
    <title>Question #9</title>
    <idx>HW2 Q9</idx>
    <interactive aspect="9:9" platform="javascript" source="https://cdn.jsdelivr.net/gh/dmfranklin/quantum-module/source/loader.js">
      <script>
        identicalCircuitWidget({
          circuit: "L2_4_Identical",
          instantFeedback: false,
          allowedGates: "XS*"
        });
