    </exercise>
    <exercise label="Quiz1_17">
      <statement>
        <p>What is the state at the end of the quantum circuit below, starting with the state <m>\ket{101}</m>
          ?</p>
        <p>
          <image source="Quiz1_17.png" width="85%" />
        </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>
              <m>\ket{111}</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>
              <m>\ket{101}</m>
            </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>50% chance of <m>\ket{001}</m> and <m>\ket{101}</m></p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>50% chance of <m>\ket{101}</m> and <m>\ket{111}</m></p>
          </statement>
        </choice>
      </choices>
      <hint>
        <statement>
          <p>Try expressing the starting state in visual representation, and then trace
            through the circuit, one gate at a time.</p>
        </statement>
      </hint>
    </exercise>
    <exercise label="Quiz1_18">
      <statement>
        <p> Write code using Qiskit to build the following circuit:</p>
        <p>
          <image source="Quiz1_18.png" width="85%" />
        </p>
      </statement>
      <program interactive="activecode" language="python3">
        <preamble>
    from qiskit import QuantumCircuit

    # TODO: Pass in the correct parameter to create a circuit with 2 qubits
    </preamble>
        <code>
    circuit = QuantumCircuit(...)

    # TODO: Write code to create the appropriate circuit

    </code>
        <postamble>
    # Draw the circuit
    print(circuit.draw())
    </postamble>
      </program>
    </exercise>
    <exercise label="Quiz1_19">
      <statement>
        <p>What can the following sequence of gates be simplified to?</p>
        <p>
          <image source="Quiz1_19.png" width="80%" />
        </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>one <c>SWAP</c></p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>one <c>CNOT</c> with the control on the upper qubit and the target on the lower qubit</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>one <c>NOT</c> on each qubit</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>one <c>NOT</c> on the upper qubit</p>
          </statement>
        </choice>
      </choices>
      <hint>
        <p> Go through possible starting states (like <m>\ket{00}</m>, <m>\ket{01}</m>, <m>\ket{10}</m>, <m>\ket{11}</m>) and see
          what the result of running the given gates on each state is. </p>
      </hint>
    </exercise>
    <exercise label="Quiz1_20">
      <statement>
        <p>
          Select all that is true about quantum measurements:
        </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>Measurement can affect the state being measured</p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p>Multiple subsequent measurements of a quantum state in superposition will
              result in
              the
              same value</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>If you know the superposition state of a quantum state, you can accurately
              predict a
              measurement made on it</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>It is possible in all cases to construct a measurement to completely measure
              both a
              state's superposition and phase</p>
          </statement>
        </choice>
      </choices>
    </exercise>
  </exercises>
</section>
