    <exercise label="HW9_Q4">
      <title>Question #4</title>
      <idx>HW9 Q4</idx>
      <statement>
        <p> The key(s) to performance for Bernstein-Vazirani is/are:</p>
      </statement>
      <choices randomize="yes">
        <choice>
          <statement>
            <p> Placing values in superposition so all guesses were tested simultaneously </p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p> Placing values in superposition so the CNOT received inputs in superposition </p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p>Phase Kick-Back</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>Interference</p>
          </statement>
        </choice>
      </choices>
    </exercise>

