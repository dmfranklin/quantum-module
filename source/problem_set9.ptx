    <exercise label="HW9_Q7">
      <title>Question #7</title>
      <idx>HW9 Q7</idx>
      <statement>
        <p> In order to implement the Bernstein-Vazirani algorithm, what about this quantum circuit
          should be changed? </p>
        <image source="HW9_Q7.png" width="35%" />
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>All four qubits should be put through H gates before the BernVaz oracle. </p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> Two of the qubits, q1 and q2, should be prepared by being passed through NOT gates
              before the BernVaz oracle.</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>The H gates should be moved from after the oracle to before the oracle.</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p> No change is necessary; it correctly implements the Bernstein-Vazirani algorithm. </p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW9_Q8">
      <title>Question #8</title>
      <idx>HW9 Q8</idx>
      <statement>
        <p> Suppose I have a BernVaz oracle with 4 input bits and 1 output bit. How many times do I
          need to run the BernVaz oracle if I am limited to using <em>classical bits</em> and the
          best classical approach? </p>
      </statement>
      <choices randomize="yes">
        <choice correct="yes">
          <statement>
            <p>4</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>3</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>2</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>1</p>
          </statement>
        </choice>
      </choices>
    </exercise>

    <exercise label="HW9_Q9">
      <title>Question #9</title>
      <idx>HW9 Q9</idx>
      <statement>
        <p> Suppose I have a BernVaz oracle with 4 input bits and 1 output bit. How many times do I
          need to run the BernVaz oracle if I use <em>qubits</em> and our quantum algorithm? </p>
      </statement>
      <choices randomize="yes">
        <choice>
          <statement>
            <p>4</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>3</p>
          </statement>
        </choice>
        <choice>
          <statement>
            <p>2</p>
          </statement>
        </choice>
        <choice correct="yes">
          <statement>
            <p>1</p>
          </statement>
        </choice>
      </choices>
    </exercise>

